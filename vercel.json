{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/public",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/auth/(.*)",         "dest": "https://YOUR-RAILWAY-URL.up.railway.app/api/auth/$1" },
    { "src": "/api/user(.*)",          "dest": "https://YOUR-RAILWAY-URL.up.railway.app/api/user$1" },
    { "src": "/api/notifications(.*)", "dest": "https://YOUR-RAILWAY-URL.up.railway.app/api/notifications$1" },
    { "src": "/api/availability(.*)",  "dest": "https://YOUR-RAILWAY-URL.up.railway.app/api/availability$1" },
    { "src": "/api/(.*)",              "dest": "https://YOUR-RAILWAY-URL.up.railway.app/api/$1" }
  ]
}
